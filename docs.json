{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Knowledge base",
  "description": "Onboarding, employee handbook, HR guides, IT help, company policies, and department runbooks.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Team",
        "groups": [
          {
            "group": "Members",
            "pages": ["team/matt"]
          }
        ]
      },
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Internal",
            "pages": ["docs/infra", "docs/shanai-tool"]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Submit IT ticket",
        "href": "/it-security/access-requests"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Employee portal",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
