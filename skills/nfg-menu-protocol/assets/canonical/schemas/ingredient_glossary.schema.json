{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ingredient_glossary entry",
  "type": "object",
  "required": ["term_ja", "term_en", "japan_unique"],
  "properties": {
    "term_ja": {"type": "string"},
    "term_en": {"type": "string", "description": "Policy B: plain English if it exists; Romaji+gloss only if japan_unique"},
    "japan_unique": {"type": "boolean"},
    "allergen_flag": {"type": "array", "items": {"type": "string"}},
    "region": {"type": "string"},
    "note": {"type": "string"}
  }
}
