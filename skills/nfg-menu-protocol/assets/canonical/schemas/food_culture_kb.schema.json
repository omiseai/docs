{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "food_culture_kb entry",
  "type": "object",
  "required": ["id", "dish_ja", "dish_en", "narrative_en", "source"],
  "properties": {
    "id": {"type": "string"},
    "dish_ja": {"type": "string"},
    "dish_en": {"type": "string"},
    "region": {"type": "string"},
    "narrative_en": {"type": "string"},
    "source": {"type": "string", "description": "authoritative source, e.g. MAFF regional cuisine database"},
    "verification_rank": {"type": "string", "enum": ["S", "A", "B", "C"]}
  }
}
